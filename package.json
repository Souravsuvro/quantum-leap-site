    "@types/jest": "^29.5.14",
    "@types/react-router-dom": "5.3.3",
    "eslint-config-react-app": "^7.0.1",
    "eslint-plugin-flowtype": "^8.0.3",
    "eslint-plugin-jest": "^28.10.0",
    "eslint-plugin-testing-library": "^7.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "lighthouse": "^10.0.0",
    "prettier": "^3.4.2",
    "react-app-rewired": "^2.2.1",
    "webpack-bundle-analyzer": "^4.9.1"
  },
  "engines": {
    "node": ">=20.12.2",
    "npm": ">=10.9.0"
  }
