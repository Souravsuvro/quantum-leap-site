    "framer-motion": "^11.16.0",
    "process": "^0.11.10",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-helmet-async": "^2.0.5",
    "react-router": "7.1.1",
    "react-router-dom": "7.1.1",
    "react-scripts": "5.0.1",
    "stream-browserify": "^3.0.0",
